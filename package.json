{
  "name": "mcp_test",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "nodemon": "^3.1.9",
    "typescript": "^5.7.2"
  },
  "nodemonConfig": {
    "watch": [
      "src",
      "views"
    ],
    "ext": "ts,ejs",
    "execMap": {
      "ts": "tsc && node dist/server.js"
    }
  }
}
